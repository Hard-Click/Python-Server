# Gemini (임베딩용) — Google AI Studio에서 발급 (aistudio.google.com/apikey)
GEMINI_API_KEY=...

# Qdrant Cloud
QDRANT_URL=https://xxxx-xxxx.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=...

# error-router (배치 실패 시 Slack 알림) — 종준 스케줄러와 동일 서비스 재사용. 예: http://<python-ec2-ip>:4000
# 미설정이면 알림 비활성(로컬/테스트). 크론 운영 환경에만 채우면 됨.
ERROR_ROUTER_URL=http://...:4000

# 공유 RDS (백엔드와 동일 MySQL) — 배치 인덱서가 퀴즈 문제를 직접 읽음 (읽기 전용 계정 권장)
DB_HOST=...
DB_PORT=3306
DB_USER=...
DB_PASSWORD=...
DB_NAME=Hard-Click
